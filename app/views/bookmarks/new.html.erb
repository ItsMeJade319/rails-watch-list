

<div class="container container-fluid align-items-center pt-5">
   <h1>Create a new Bookmark</h1>
   <div class="container border p-3 bg-light">
    <%= simple_form_for [@list, @bookmark] do |f| %>
      <%= f.association :movie  %>
      <%= f.input :comment %>
      <%= f.submit "Create Bookmark", class: 'btn btn-primary my-submit' %>
    <% end %>
   </div>
</div>
